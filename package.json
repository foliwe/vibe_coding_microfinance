{
  "name": "microfinance-credit-union",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace @credit-union/admin",
    "dev:mobile": "npm run dev --workspace @credit-union/mobile --",
    "create:test-admin": "node scripts/create-test-admin.mjs",
    "create:test-users": "node scripts/bootstrap-test-users.mjs",
    "test:e2e": "playwright test",
    "test:e2e:admin": "playwright test tests/e2e/admin-panel.spec.ts",
    "lint": "npm run lint --workspaces --if-present",
    "test": "node --test tests/**/*.test.mjs",
    "android": "npm run android --workspace @credit-union/mobile --",
    "ios": "npm run ios --workspace @credit-union/mobile --"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2"
  }
}
