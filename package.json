{
  "name": "microfinance-credit-union",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace @credit-union/admin",
    "dev:mobile": "npm run dev --workspace @credit-union/mobile",
    "create:test-admin": "node scripts/create-test-admin.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "test": "node --test tests/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2"
  }
}
